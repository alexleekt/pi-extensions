# pi-bump task runner
# https://github.com/casey/just

default:
    @just --list

check:
    npm run check

test:
    node test-integration.mjs

dry-run:
    npm publish --dry-run

publish:
    npm publish

release version:
    git tag -a "@alexleekt/pi-bump@{{version}}" -m "Release @alexleekt/pi-bump@{{version}}"
    git push origin "@alexleekt/pi-bump@{{version}}"
    @echo "Tag @alexleekt/pi-bump@{{version}} pushed. GitHub Actions will publish to npm."
