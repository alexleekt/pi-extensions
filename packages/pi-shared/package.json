{
    "name": "@alexleekt/pi-shared",
    "version": "0.1.2",
    "description": "The glue that holds the monorepo together. Shared types and utilities for Pi extensions.",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "pi-package",
        "pi-extension",
        "pi",
        "shared",
        "utilities",
        "types"
    ],
    "author": "Alex Lee <657215+alexleekt@users.noreply.github.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alexleekt/pi-extensions.git"
    },
    "homepage": "https://github.com/alexleekt/pi-extensions/tree/main/packages/pi-shared#readme",
    "bugs": {
        "url": "https://github.com/alexleekt/pi-extensions/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "types",
        "session.ts",
        "prompt-eval.ts"
    ],
    "exports": {
        "./session": "./session.ts",
        "./types": "./types/pi.ts",
