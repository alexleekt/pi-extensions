{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true
    },
    "include": [
        "index.ts",
        "tool/**/*.ts",
        "fallback/**/*.ts",
        "types/**/*.d.ts",
        "shared/**/*.ts"
    ],
    "exclude": ["node_modules", "webview"]
}
